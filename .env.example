# ─── Supabase (Required) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ─── Supabase Edge Function Secrets (set via supabase secrets set) ───────────
# SUPABASE_SERVICE_ROLE_KEY=  # NEVER expose in client code
# GROQ_API_KEY=               # Primary LLM provider
# AGENT_MODE=demo             # demo | sandbox | prod

# ─── Communication Providers ────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# RESEND_API_KEY=

# ─── DMS/CRM Integrations ──────────────────────────────────────────────────
# DEALERTRACK_API_KEY=
# PBS_API_KEY=

# ─── Social/Webhook ────────────────────────────────────────────────────────
# META_VERIFY_TOKEN=

# ─── CORS (comma-separated origins for edge function access) ───────────────
# ALLOWED_ORIGINS=https://your-app.com,https://localhost:8080
