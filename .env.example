# ─── Supabase (Required) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ─── Supabase Edge Function Secrets ──────────────────────────────────────────
# Set via: supabase secrets set KEY=value   (NEVER commit real values)
# These run server-side in Deno edge functions only — never exposed to browser.
#
# SUPABASE_SERVICE_ROLE_KEY=   # Required for edge functions writing to DB
# GROQ_API_KEY=                # LLM provider (llama-3.3-70b-versatile via Groq)
# AGENT_MODE=demo              # REQUIRED — demo | sandbox | prod
#                              #   demo: mock LLM responses (no API key needed)
#                              #   prod: fail-closed if GROQ_API_KEY is missing
# ALLOWED_ORIGINS=https://your-app.com,https://localhost:8080

# ─── Telephony (Twilio) ──────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=           # HMAC-SHA1 webhook signature verification
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxx

# ─── Social / Meta Webhooks ──────────────────────────────────────────────────
# META_VERIFY_TOKEN=           # Webhook verification token (any string you choose)
# META_APP_SECRET=             # HMAC-SHA256 webhook signature verification

# ─── Custom Webhook Security ─────────────────────────────────────────────────
# WEBHOOK_SECRET=              # Shared secret for custom webhook HMAC-SHA256 verification

# ─── DMS / CRM Integrations ──────────────────────────────────────────────────
# DEALERTRACK_API_KEY=
# PBS_API_KEY=
